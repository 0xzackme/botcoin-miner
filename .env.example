# ─── Required ───────────────────────────────────────────
BANKR_API_KEY=bk_your_api_key_here

# ─── LLM Models ────────────────────────────────────────
# LLM_MODEL=gemini-2.5-flash           # Primary (fast, cheap)
# LLM_MODEL_VERIFY=gemini-2.5-pro      # Verification (accurate)

# ─── Auto Credit Top-Up ────────────────────────────────
# CREDIT_MIN_USD=2                      # Trigger top-up below this
# CREDIT_TOPUP_USD=5                    # Amount to top up
# CREDIT_TOPUP_TOKEN=USDC              # Token for top-up
# CREDIT_CHECK_INTERVAL_MS=300000      # Check every 5 min

# ─── Coordinator ────────────────────────────────────────
# COORDINATOR_URL=https://coordinator.agentmoney.net

# ─── Server ─────────────────────────────────────────────
# PORT=3000
# AUTH_PASSWORD=                        # Set to protect dashboard
# ENCRYPTION_KEY=                       # 64 hex chars for API key encryption persistence

# ─── Mining ─────────────────────────────────────────────
# MAX_CONSECUTIVE_FAILURES=5            # Pause after N failures
